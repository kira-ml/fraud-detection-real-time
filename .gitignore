# ================================
# Python
# ================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
eggs/
*.egg
venv/
.venv/
env/
.env/

# ================================
# Jupyter Notebooks
# ================================
.ipynb_checkpoints/
*.ipynb

# ================================
# Data Files
# ================================
data/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/monitoring/.gitkeep
!data/external/.gitkeep

# ================================
# Data Logging (EDA, Validation, Visualizations)
# ================================
data/data_logging/*
!data/data_logging/.gitkeep




# ================================
# Model Artifacts (Binary)
# ================================
# Store in MLflow artifact store, S3, or DVC — NOT Git
models/*.pkl
models/*.pth
models/*.onnx
models/*.h5
models/*.pt
models/*.joblib
models/*.pb
models/*.bin

# ================================
# Model Evaluation Reports
# ================================
# Keep these in Git (small, diffable JSON)
!models/*_evaluation.json
!models/*_metrics.json

# ================================
# Pipeline Artifacts (Scalers, Configs)
# ================================
artifacts/*
!artifacts/.gitkeep

# ================================
# Reports
# ================================
reports/*
!reports/.gitkeep
!reports/eda/.gitkeep

# ================================
# Logs
# ================================
logs/
*.log

# ================================
# Environment and Secrets
# ================================
.env
.env.*
*.env
config/secrets.yaml

# ================================
# IDE and Editor
# ================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini